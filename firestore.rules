rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Queries: Only owner can read/write their own queries
    match /queries/{queryId} {
      function isValidQuery(data) {
        return data.userId is string && data.userId.size() > 0 &&
               data.query is string && data.query.size() > 0 && data.query.size() < 5000 &&
               data.response is string && data.response.size() > 0 && data.response.size() < 10000;
      }

      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidQuery(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == resource.data.userId &&
                      isValidQuery(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Interest Rates: Publicly readable, only admin can write
    match /rates/{rateId} {
      allow read: if true;
      allow write: if false; // Only via backend/admin (if configured)
    }

    // Logs: Only admin can read/write
    match /logs/{logId} {
      allow read, write: if false; // Restricted
    }
  }
}
